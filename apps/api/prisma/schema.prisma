generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  FAN
  ARTIST
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
}

enum WalletStatus {
  UNVERIFIED
  VERIFIED
  DISABLED
}

enum SessionStatus {
  DRAFT
  LIVE
  ENDED
  CANCELLED
}

enum TipStatus {
  DRAFT
  PENDING
  CONFIRMED
  FAILED
  REFUNDED
}

enum TipAssetCode {
  XLM
  USDC
}

enum AdminScope {
  SUPPORT
  MODERATION
  OPERATIONS
  SUPER_ADMIN
}

model User {
  id             String          @id @default(cuid())
  email          String?         @unique
  publicKey      String?         @unique
  username       String          @unique
  displayName    String?
  bio            String?
  avatarUrl      String?
  role           UserRole        @default(FAN)
  status         UserStatus      @default(ACTIVE)
  consentedAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  artistProfile  ArtistProfile?
  wallets        Wallet[]
  fanTips        Tip[]           @relation("FanTips")
  adminRoles     AdminRole[]
  auditLogs      AuditLog[]      @relation("AuditActor")
  reportedEvents AuditLog[]      @relation("AuditTargetUser")

  @@index([role, status])
}

model ArtistProfile {
  id               String      @id @default(cuid())
  userId           String      @unique
  stageName        String
  slug             String      @unique
  city             String?
  country          String?
  genres           String[]
  tagline          String?
  bannerUrl        String?
  isFeatured       Boolean     @default(false)
  tippingEnabled   Boolean     @default(false)
  onboardingStep   Int         @default(1)
  currentWalletId  String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentWallet    Wallet?     @relation("ActiveWallet", fields: [currentWalletId], references: [id], onDelete: SetNull)
  wallets          Wallet[]
  sessions         Session[]
  receivedTips     Tip[]       @relation("ArtistTips")

  @@index([isFeatured, stageName])
}

model Wallet {
  id                String        @id @default(cuid())
  userId            String
  artistProfileId   String?
  network           String        @default("stellar-testnet")
  assetCode         TipAssetCode  @default(XLM)
  publicKey         String        @unique
  status            WalletStatus  @default(UNVERIFIED)
  isDefaultForTips  Boolean       @default(false)
  verifiedAt        DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  artistProfile     ArtistProfile? @relation(fields: [artistProfileId], references: [id], onDelete: SetNull)
  activeForArtist   ArtistProfile[] @relation("ActiveWallet")
  receivedTips      Tip[]

  @@index([userId, status])
}

model Session {
  id               String        @id @default(cuid())
  artistProfileId  String
  title            String
  description      String?
  streamUrl        String?
  coverImageUrl    String?
  status           SessionStatus @default(DRAFT)
  scheduledFor     DateTime?
  startedAt        DateTime?
  endedAt          DateTime?
  totalTipsCount   Int           @default(0)
  totalTipsAmount  Decimal       @default(0) @db.Decimal(18, 7)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  artistProfile    ArtistProfile @relation(fields: [artistProfileId], references: [id], onDelete: Cascade)
  tips             Tip[]

  @@index([status, scheduledFor])
  @@index([artistProfileId, status])
}

model Tip {
  id                String        @id @default(cuid())
  fanId             String
  artistProfileId   String
  sessionId         String?
  walletId          String?
  amount            Decimal       @db.Decimal(18, 7)
  assetCode         TipAssetCode
  status            TipStatus     @default(DRAFT)
  txHash            String?       @unique
  ledgerSequence    Int?
  note              String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  confirmedAt       DateTime?
  fan               User          @relation("FanTips", fields: [fanId], references: [id], onDelete: Restrict)
  artistProfile     ArtistProfile @relation("ArtistTips", fields: [artistProfileId], references: [id], onDelete: Restrict)
  session           Session?      @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  wallet            Wallet?       @relation(fields: [walletId], references: [id], onDelete: SetNull)

  @@index([sessionId, status, createdAt])
  @@index([fanId, createdAt])
  @@index([artistProfileId, status])
}

model AdminRole {
  id          String      @id @default(cuid())
  userId       String
  scope        AdminScope
  assignedById String?
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, scope])
  @@index([scope])
}

model AuditLog {
  id            String   @id @default(cuid())
  actorUserId    String?
  targetUserId   String?
  action         String
  entityType     String
  entityId       String
  metadata       Json?
  createdAt      DateTime @default(now())
  actor          User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  targetUser     User?    @relation("AuditTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
model User {
  id        String   @id @default(cuid())
  publicKey String   @unique
  username  String?
  bio       String?
  createdAt DateTime @default(now())
}
